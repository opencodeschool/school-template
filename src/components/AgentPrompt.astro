interface Props {
  title: string;
  prompt?: string;
}

const { title, prompt } = Astro.props;
---

<div class="agent-prompt-card hidden mb-8" data-lesson-title={title} data-prompt={prompt}>
  <p class="text-sm text-gray-500 dark:text-stone-400 mb-2 font-mono uppercase tracking-wider text-xs">
    Prompt for your AI agent
  </p>
  <div class="agent-prompt-box relative rounded-lg overflow-hidden">
    <pre class="agent-prompt-text px-5 py-4 font-mono text-sm text-gray-800 dark:text-stone-200 overflow-x-auto whitespace-pre-wrap leading-relaxed"></pre>
    <button
      class="agent-prompt-copy absolute top-2.5 right-2.5 px-2.5 py-1 text-xs font-mono font-medium rounded transition-colors cursor-pointer theme-button"
    >
      Copy
    </button>
  </div>
  <p class="agent-prompt-confirm hidden mt-5 text-sm font-mono text-gray-500 dark:text-stone-400">
    Copied! Now paste that into your AI agent...
  </p>
</div>

<script is:inline>
  (function() {
    if (!window.school) return;
    var studentId = window.school.getStudentId();
    if (!studentId) return;

    var cards = document.querySelectorAll(".agent-prompt-card");
    cards.forEach(function(card) {
      var lessonTitle = card.getAttribute("data-lesson-title");
      var promptText = card.querySelector(".agent-prompt-text");
      var copyBtn = card.querySelector(".agent-prompt-copy");
      var confirm = card.querySelector(".agent-prompt-confirm");
      if (!promptText) return;

      var customPrompt = card.getAttribute("data-prompt");
      var schoolName = document.querySelector("[data-school-name]");
      var name = schoolName ? schoolName.getAttribute("data-school-name") : "this school";
      var prompt = "I'm a student at " + name + ". My student ID is " + studentId + ".\n\n" + (customPrompt || "Let's work on the \"" + lessonTitle + "\" lesson together!") + "\n\nFetch " + window.location.origin + "/llms.txt for instructions.";
      promptText.textContent = prompt;
      card.classList.remove("hidden");

      if (copyBtn) {
        copyBtn.addEventListener("click", function() {
          navigator.clipboard.writeText(prompt).then(function() {
            if (confirm) confirm.classList.remove("hidden");
          });
        });
      }
    });
  })();
</script>
