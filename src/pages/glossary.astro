---
export const prerender = true;

import Base from "../layouts/Base.astro";
---

<Base title="Glossary" description="Definitions of common terms used in this school.">
  <div class="mb-6">
    <a href="/" class="text-sm text-gray-500 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">
      &larr; Home
    </a>
  </div>

  <header class="mb-8">
    <h1 class="text-3xl font-bold">Glossary</h1>
    <p class="text-gray-600 dark:text-gray-400 mt-2">Definitions of common terms used in this school.</p>
  </header>

  <article class="prose dark:prose-invert max-w-none">
    <!-- Add glossary terms here as you create lesson content. Example: -->
    <!-- <h2 id="term">Term</h2> -->
    <!-- <p>Definition of the term.</p> -->
    <p class="text-gray-500 dark:text-stone-500 italic">No glossary terms yet. Add them as you create lesson content.</p>
  </article>
</Base>
