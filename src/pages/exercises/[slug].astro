export const prerender = true;

import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const exercises = await getCollection("exercises");
  return exercises.map((exercise) => ({
    params: { slug: exercise.data.slug },
    props: { exercise },
  }));
}

const { exercise } = Astro.props;
const { Content } = await render(exercise);

const allExercises = (await getCollection("exercises")).sort((a, b) => a.data.order - b.data.order);
const currentIndex = allExercises.findIndex((e) => e.data.slug === exercise.data.slug);
const next = currentIndex < allExercises.length - 1 ? allExercises[currentIndex + 1] : null;
---

<Base title={exercise.data.title} description={exercise.data.description}>
  <div class="mb-6">
    <a href="/exercises" class="text-sm text-gray-500 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">
      &larr; All exercises
    </a>
  </div>

  <header class="mb-8">
    <p class="text-sm font-mono text-gray-400 dark:text-gray-600 mb-1">Exercise {exercise.data.order}</p>
    <h1 class="text-3xl font-bold">{exercise.data.title}</h1>
    <p class="text-gray-600 dark:text-gray-400 mt-2">{exercise.data.description}</p>
  </header>

  <div id="exercise-completed-banner" class="theme-banner hidden mb-6 rounded-lg px-4 py-3 text-sm font-medium">
    <span id="exercise-completed-text">You completed this exercise!</span>
  </div>

  <div id="exercise-enroll-nudge" class="hidden mb-8 rounded-xl theme-banner px-6 py-5">
    <p class="text-base font-medium mb-1">This exercise works best with an AI agent</p>
    <p class="text-sm opacity-80 mb-3">Enroll to get a student ID. Then paste the exercise prompt into your AI agent, and it will guide you through this project step by step.</p>
    <a href="/" class="theme-button inline-block rounded-lg px-4 py-2 text-sm font-medium">Enroll for free</a>
  </div>

  <article class="prose dark:prose-invert max-w-none">
    <Content />
  </article>

  <!-- Exercise action: combined mark-complete + next-exercise button -->
  <div id="exercise-action" class="mt-10 pt-6 border-t border-gray-200 dark:border-stone-800 hidden">
    {next ? (
      <button
        id="exercise-action-btn"
        data-next-url={`/exercises/${next.data.slug}`}
        class="theme-button flex w-full justify-center cursor-pointer items-center gap-2 rounded-lg px-6 py-4 text-sm font-medium disabled:opacity-50 disabled:cursor-not-allowed select-none"
      >
        <span id="exercise-action-label">Next exercise: {next.data.title} &rarr;</span>
      </button>
    ) : (
      <button
        id="exercise-action-btn"
        class="theme-button flex w-full justify-center cursor-pointer items-center gap-2 rounded-lg px-6 py-4 text-sm font-medium disabled:opacity-50 disabled:cursor-not-allowed select-none"
      >
        <span id="exercise-action-label">Mark this exercise as complete</span>
      </button>
    )}
  </div>

  <script is:inline define:vars={{ exerciseSlug: exercise.data.slug }}>
    (function() {
      var action = document.getElementById("exercise-action");
      var btn = document.getElementById("exercise-action-btn");
      var label = document.getElementById("exercise-action-label");
      var banner = document.getElementById("exercise-completed-banner");
      var bannerText = document.getElementById("exercise-completed-text");
      var nudge = document.getElementById("exercise-enroll-nudge");
      if (!action || !btn || !window.school) return;

      // Show enroll nudge to unenrolled visitors, hide it once enrolled
      if (!window.school.getStudentId()) {
        if (nudge) nudge.classList.remove("hidden");
        return;
      }
      if (nudge) nudge.classList.add("hidden");
      action.classList.remove("hidden");

      var nextUrl = btn.getAttribute("data-next-url");
      var originalLabel = label.textContent;
      var wasAlreadyComplete = window.school.isExerciseComplete && window.school.isExerciseComplete(exerciseSlug);

      function formatBannerText(completion) {
        var text = "You completed this exercise!";
        if (completion && completion.completedAt) {
          var date = new Date(completion.completedAt).toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });
          var via = completion.source === "agent" ? "via your AI agent" : "in the browser";
          text = "You completed this exercise on " + date + " " + via + ".";
        }
        return text;
      }

      function getExerciseCompletion(slug) {
        var progress = window.school._progressCache;
        if (!progress || !progress.completedExercises) return null;
        for (var i = 0; i < progress.completedExercises.length; i++) {
          if (progress.completedExercises[i].slug === slug) return progress.completedExercises[i];
        }
        return null;
      }

      function showBanner() {
        if (!banner) return;
        var completion = getExerciseCompletion(exerciseSlug);
        if (bannerText) bannerText.textContent = formatBannerText(completion);
        banner.classList.remove("hidden");
      }

      function setCompleted() {
        showBanner();
        if (nextUrl) {
          window.location.href = nextUrl;
        } else {
          label.textContent = "Exercise complete!";
          btn.disabled = true;
        }
      }

      // If already complete, show the banner and make the button navigate directly
      if (window.school.isExerciseComplete && window.school.isExerciseComplete(exerciseSlug)) {
        showBanner();
        if (nextUrl) {
          btn.addEventListener("click", function() { window.location.href = nextUrl; });
        } else {
          label.textContent = "Exercise complete!";
          btn.disabled = true;
        }
      } else {
        btn.addEventListener("click", async function() {
          btn.disabled = true;
          label.textContent = "Saving...";
          var progress = await window.school.markExerciseComplete(exerciseSlug);
          if (progress) {
            window.school.updateAllCheckmarks();
            setCompleted();
          } else {
            btn.disabled = false;
            label.textContent = originalLabel;
          }
        });
      }

      // Update after progress fetch completes (in case cached state was stale)
      var origUpdate = window.school.updateAllCheckmarks.bind(window.school);
      window.school.updateAllCheckmarks = function() {
        origUpdate();
        if (nudge && window.school.getStudentId()) nudge.classList.add("hidden");
        if (window.school.isExerciseComplete && window.school.isExerciseComplete(exerciseSlug)) {
          showBanner();
          if (nextUrl && !wasAlreadyComplete && label.textContent === originalLabel) {
            setCompleted();
          }
        }
      };
    })();
  </script>
</Base>
