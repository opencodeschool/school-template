export const prerender = true;

import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const exercises = (await getCollection("exercises")).sort((a, b) => a.data.order - b.data.order);
---

<Base title="Exercises" description="Hands-on projects for applying what you've learned.">
  <div class="mb-6">
    <a href="/" class="text-sm text-gray-500 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">
      &larr; Home
    </a>
  </div>

  <header class="mb-8">
    <h1 class="text-3xl font-bold">Exercises</h1>
    <p class="text-gray-600 dark:text-gray-400 mt-2">
      Hands-on projects where you apply what you've learned to build real things &mdash; websites, media tools, browser automation, and more.
    </p>
  </header>

  <div id="exercise-enroll-nudge" class="hidden mb-8 rounded-xl theme-banner px-6 py-5">
    <p class="text-base font-medium mb-1">Exercises work best with an AI agent</p>
    <p class="text-sm opacity-80 mb-3">Enroll to get a student ID. Then paste the exercise prompt into your AI agent, and it will guide you through each project step by step.</p>
    <a href="/" class="theme-button inline-block rounded-lg px-4 py-2 text-sm font-medium">Enroll for free</a>
  </div>

  <ol class="divide-y divide-gray-200 dark:divide-stone-800">
    {exercises.map((exercise) => {
      const isStub = exercise.body?.trim() === "Coming soon.";
      const href = `/exercises/${exercise.data.slug}`;
      return (
        <li data-exercise-slug={exercise.data.slug} data-exercise-stub={isStub ? "true" : "false"}>
          <div class="exercise-row flex flex-col gap-3 py-3 transition-colors sm:flex-row sm:items-center sm:justify-between">
            <a
              href={href}
              class="exercise-link group flex min-w-0 items-center gap-3"
            >
              <span
                class="exercise-status flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-gray-300 bg-gray-100/70 text-white dark:border-stone-700 dark:bg-stone-900/70"
                aria-hidden="true"
              >
                <span class="exercise-status-dot h-2 w-2 rounded-full bg-gray-400 dark:bg-stone-500"></span>
                <span class="exercise-check hidden h-full w-full items-center justify-center text-xs font-bold leading-none">&#10003;</span>
              </span>
              <div class="min-w-0">
                <h3 class:list={[
                  "exercise-title font-medium transition-colors",
                  isStub && "text-gray-400 dark:text-gray-600",
                ]}>
                  {exercise.data.title}
                  {isStub && <span class="ml-2 text-xs font-normal text-gray-400 dark:text-gray-600">(coming soon)</span>}
                </h3>
                <p class="exercise-description mt-0.5 text-sm text-gray-500 dark:text-gray-500">{exercise.data.description}</p>
              </div>
            </a>
          </div>
        </li>
      );
    })}
  </ol>

  <script is:inline>
    (function() {
      // Show enroll nudge if not enrolled
      var nudge = document.getElementById("exercise-enroll-nudge");
      if (nudge && !window.school.getStudentId()) {
        nudge.classList.remove("hidden");
      }

      function updateExerciseCheckmarks() {
        var items = document.querySelectorAll("[data-exercise-slug]");
        items.forEach(function(li) {
          var slug = li.getAttribute("data-exercise-slug");
          var done = window.school.isExerciseComplete && window.school.isExerciseComplete(slug);
          var dot   = li.querySelector(".exercise-status-dot");
          var check = li.querySelector(".exercise-check");
          var ring  = li.querySelector(".exercise-status");
          if (done) {
            if (dot)   dot.classList.add("hidden");
            if (check) { check.classList.remove("hidden"); check.style.display = "flex"; }
            if (ring)  { ring.classList.add("theme-check-complete"); ring.classList.remove("bg-gray-100/70", "dark:bg-stone-900/70"); }
          } else {
            if (dot)   dot.classList.remove("hidden");
            if (check) { check.classList.add("hidden"); check.style.display = ""; }
            if (ring)  { ring.classList.remove("theme-check-complete"); ring.classList.add("bg-gray-100/70", "dark:bg-stone-900/70"); }
          }
        });
      }

      // Run on load and whenever progress updates
      if (window.school.getStudentId()) updateExerciseCheckmarks();
      window.school._onProgressUpdate = (function(prev) {
        return function() { if (prev) prev(); updateExerciseCheckmarks(); };
      })(window.school._onProgressUpdate);
    })();
  </script>
</Base>
