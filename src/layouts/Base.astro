      window.__applySchoolTheme = function(themeName) {
        var palette = window.__schoolThemePalettes[themeName] || window.__schoolThemePalettes.blue;
        var root = document.documentElement;
        root.style.setProperty("--theme-solid", palette.solid);
        root.style.setProperty("--theme-solid-hover", palette.solidHover);
        root.style.setProperty("--theme-link", palette.link);
        root.style.setProperty("--theme-link-dark", palette.linkDark);
        root.style.setProperty("--theme-soft-bg", palette.softBg);
        root.style.setProperty("--theme-soft-border", palette.softBorder);
        root.style.setProperty("--theme-soft-text", palette.softText);
        root.style.setProperty("--theme-soft-bg-dark", palette.softBgDark);
        root.style.setProperty("--theme-soft-border-dark", palette.softBorderDark);
        root.style.setProperty("--theme-soft-text-dark", palette.softTextDark);
        root.style.setProperty("--theme-card-text", palette.cardText);
        root.dataset.themeColor = window.__schoolThemePalettes[themeName] ? themeName : "blue";
      };

      try {
        window.__applySchoolTheme(localStorage.getItem("themeColor") || "blue");
      } catch {
        window.__applySchoolTheme("blue");
      }
    </script>
    <script is:inline>
      if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
        document.documentElement.classList.add("dark");
      }
      window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (e) => {
        document.documentElement.classList.toggle("dark", e.matches);
      });
    </script>
    <script is:inline>
      // Progress tracking API — defined in <head> so page-level scripts can use it
      window.school = {
        getStudentId() {
          return localStorage.getItem("studentId");
        },

        setStudentId(id) {
          localStorage.setItem("studentId", id);
        },

        getDeviceId() {
          let deviceId = localStorage.getItem("deviceId");
          if (!deviceId) {
            deviceId = crypto.randomUUID();
            localStorage.setItem("deviceId", deviceId);
          }
          return deviceId;
        },

        getThemeColor() {
          return localStorage.getItem("themeColor") || "blue";
        },

        getThemePalettes() {
          return window.__schoolThemePalettes;
        },

        setThemeColor(themeName) {
          const palettes = this.getThemePalettes();
          const nextTheme = palettes[themeName] ? themeName : "blue";
          localStorage.setItem("themeColor", nextTheme);
          window.__applySchoolTheme(nextTheme);
          return nextTheme;
        },

        getCachedProgress() {
          try {
            const p = JSON.parse(localStorage.getItem("progress") || "null");
            this._progressCache = p;
            return p;
          } catch { return null; }
        },

        setCachedProgress(progress) {
          this._progressCache = progress;
          localStorage.setItem("progress", JSON.stringify(progress));
        },

        _progressCache: null,

        isLessonComplete(slug) {
          const progress = this.getCachedProgress();
          return progress?.completedLessons?.some((l) => (typeof l === "string" ? l : l.slug) === slug) || false;
        },

        getLessonCompletion(slug) {
          const progress = this.getCachedProgress();
          const entry = progress?.completedLessons?.find((l) => (typeof l === "string" ? l : l.slug) === slug);
          if (!entry) return null;
          return typeof entry === "string" ? { slug: entry, completedAt: null, source: "browser" } : entry;
        },

        isExerciseComplete(slug) {
          const progress = this.getCachedProgress();
          return progress?.completedExercises?.some((e) => (typeof e === "string" ? e : e.slug) === slug) || false;
        },

        getExerciseCompletion(slug) {
          const progress = this.getCachedProgress();
          const entry = progress?.completedExercises?.find((e) => (typeof e === "string" ? e : e.slug) === slug);
          if (!entry) return null;
          return typeof entry === "string" ? { slug: entry, completedAt: null, source: "browser" } : entry;
        },

        getVisitedLessons() {
          try {
            return JSON.parse(localStorage.getItem("visitedLessons") || "[]");
          } catch { return []; }
        },

        isLessonVisited(slug) {
          return this.getVisitedLessons().includes(slug);
        },

        markLessonVisited(slug) {
          const visited = this.getVisitedLessons();
          if (!visited.includes(slug)) {
            visited.push(slug);
            localStorage.setItem("visitedLessons", JSON.stringify(visited));
          }
        },

        async enroll() {
          const deviceId = this.getDeviceId();
          const res = await fetch("/api/enroll", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ deviceId }),
          });
          if (!res.ok) throw new Error("Enrollment failed");
          const data = await res.json();
          this.setStudentId(data.studentId);
          this.setCachedProgress(data.progress);
          return data;
        },

        async fetchProgress() {
          const studentId = this.getStudentId();
          if (!studentId) return null;
          const res = await fetch(`/api/progress/${studentId}`);
          if (!res.ok) return null;
          const progress = await res.json();
          this.setCachedProgress(progress);
          return progress;
        },

        async markComplete(lessonSlug) {
          const studentId = this.getStudentId();
          if (!studentId) return null;
          const res = await fetch(`/api/progress/${studentId}`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ lessonSlug, source: "browser" }),
          });
          if (!res.ok) return null;
          const progress = await res.json();
          this.setCachedProgress(progress);
          return progress;
        },

        async markExerciseComplete(exerciseSlug) {
          const studentId = this.getStudentId();
          if (!studentId) return null;
          const res = await fetch(`/api/progress/${studentId}`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ exerciseSlug, source: "browser" }),
          });
          if (!res.ok) return null;
          const progress = await res.json();
          this.setCachedProgress(progress);
          return progress;
        },

        updateAllCheckmarks() {
          let nextIncompleteSet = false;
          document.querySelectorAll("[data-lesson-slug]").forEach((el) => {
            const slug = el.getAttribute("data-lesson-slug");
            const isStub = el.getAttribute("data-lesson-stub") === "true";
            const rowEl = el.querySelector(".lesson-row");
            const linkEl = el.querySelector(".lesson-link");
            const ctaEl = el.querySelector(".lesson-cta");
            const statusEl = el.querySelector(".lesson-status");
            const checkEl = el.querySelector(".lesson-check");
            const dotEl = el.querySelector(".lesson-status-dot");
            const complete = this.isLessonComplete(slug);
            const isNext = !complete && !isStub && !nextIncompleteSet;
            if (isNext) nextIncompleteSet = true;

            if (rowEl) {
              rowEl.classList.toggle("lesson-row--next", isNext);
            }
            if (linkEl) {
              linkEl.classList.toggle("sm:flex-1", isNext);
            }
            if (ctaEl) {
              ctaEl.classList.toggle("hidden", !isNext);
              ctaEl.classList.toggle("inline-block", isNext);
              if (isNext) ctaEl.textContent = this.isLessonVisited(slug) ? "Continue" : "Start";
            }
            if (statusEl) {
              statusEl.classList.toggle("lesson-status--complete", complete);
            }
            if (checkEl) {
              checkEl.classList.toggle("hidden", !complete);
              checkEl.classList.toggle("flex", complete);
            }
            if (dotEl) dotEl.classList.toggle("hidden", complete);
          });
          // Update sidebar lesson completion circles
          document.querySelectorAll("[data-sidebar-slug]").forEach((el) => {
            const slug = el.getAttribute("data-sidebar-slug");
            const circle = el.querySelector(".sidebar-check");
            if (circle) {
              const complete = this.isLessonComplete(slug);
              circle.textContent = complete ? "\u2713" : "";
              circle.classList.toggle("hidden", !complete);
              circle.classList.toggle("flex", complete);
            }
          });
          // Update sidebar exercise completion circles
          document.querySelectorAll("[data-sidebar-exercise-slug]").forEach((el) => {
            const slug = el.getAttribute("data-sidebar-exercise-slug");
            const circle = el.querySelector(".sidebar-exercise-check");
            if (circle) {
              const complete = this.isExerciseComplete(slug);
              circle.textContent = complete ? "\u2713" : "";
              circle.classList.toggle("hidden", !complete);
              circle.classList.toggle("flex", complete);
            }
          });
          // Update exercise completion checkmarks (homepage + exercises index)
          document.querySelectorAll("[data-exercise-slug]").forEach((el) => {
            const slug = el.getAttribute("data-exercise-slug");
            const complete = this.isExerciseComplete(slug);
            const statusEl = el.querySelector(".exercise-status");
            const checkEl = el.querySelector(".exercise-check");
            const dotEl = el.querySelector(".exercise-status-dot");
            if (statusEl) statusEl.classList.toggle("lesson-status--complete", complete);
            if (checkEl) {
              checkEl.classList.toggle("hidden", !complete);
              checkEl.classList.toggle("flex", complete);
            }
            if (dotEl) dotEl.classList.toggle("hidden", complete);
          });
        },

        updateEnrolledIndicator() {
          const id = this.getStudentId();
          const disenrollLink = document.getElementById("sidebar-disenroll-link");
          if (disenrollLink && id) {
            disenrollLink.classList.remove("hidden");
          }
        },
      };
    </script>
  </head>
  <body class="min-h-screen">
    <div class="lg:flex">
      <!-- Mobile header -->
      <header class="lg:hidden flex items-center justify-between p-4 border-b border-gray-200 dark:border-stone-800">
        <a href="/" class="font-mono font-bold text-lg">My School</a>
        <button
          id="menu-toggle"
          class="p-2 rounded-md hover:bg-gray-100 dark:hover:bg-stone-800"
          aria-label="Toggle navigation"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </header>

      <!-- Sidebar -->
      <nav
        id="sidebar"
        class="hidden lg:block w-72 shrink-0 border-r border-gray-200 dark:border-stone-800 h-screen sticky top-0 overflow-y-auto p-6"
      >
        <a href="/" class="block font-mono font-bold text-xl mb-6 px-3" data-school-name="My School">My School</a>
        <ol class="space-y-1">
          {lessons.map((lesson) => {
            const href = `/lessons/${lesson.data.slug}`;
            const isActive = currentPath === href || currentPath === `${href}/`;
            const isStub = lesson.body?.trim() === "Coming soon.";
            return (
              <li data-sidebar-slug={lesson.data.slug}>
                <a
                  href={href}
                  class:list={[
                    "flex items-center justify-between px-3 py-1.5 rounded-md text-sm transition-colors",
                    isActive
                      ? "theme-active-nav font-medium"
                      : "text-gray-600 hover:text-gray-900 hover:bg-gray-50 dark:text-stone-400 dark:hover:text-stone-200 dark:hover:bg-stone-800",
                    isStub && "opacity-50",
                  ]}
                >
                  <span>
                    <span class="text-gray-400 dark:text-stone-600 mr-1.5">{String(lesson.data.order).padStart(2, "0")}.</span>
                    {lesson.data.title}
                  </span>
                  <span class="sidebar-check theme-solid-bg w-4 h-4 rounded-full text-white text-[10px] font-bold items-center justify-center shrink-0 ml-2 hidden"></span>
                </a>
              </li>
            );
          })}
        </ol>
        <div class="mt-6 pt-4 border-t border-gray-200 dark:border-stone-800">
          <a
            href="/exercises"
            class:list={[
              "block px-3 py-1.5 rounded-md text-xs font-mono uppercase tracking-wider mb-1",
              currentPath === "/exercises" || currentPath === "/exercises/"
                ? "theme-active-nav font-medium"
                : "text-gray-500 dark:text-stone-500 hover:text-gray-900 dark:hover:text-stone-200",
            ]}
          >
            Exercises
          </a>
          <ol class="space-y-1">
            {exercises.map((exercise) => {
              const href = `/exercises/${exercise.data.slug}`;
              const isActive = currentPath === href || currentPath === `${href}/`;
              return (
                <li data-sidebar-exercise-slug={exercise.data.slug}>
                  <a
                    href={href}
                    class:list={[
                      "flex items-center justify-between px-3 py-1.5 rounded-md text-sm transition-colors",
                      isActive
                        ? "theme-active-nav font-medium"
                        : "text-gray-600 hover:text-gray-900 hover:bg-gray-50 dark:text-stone-400 dark:hover:text-stone-200 dark:hover:bg-stone-800",
                    ]}
                  >
                    <span>{exercise.data.title}</span>
                    <span class="sidebar-exercise-check theme-solid-bg w-4 h-4 rounded-full text-white text-[10px] font-bold items-center justify-center shrink-0 ml-2 hidden"></span>
                  </a>
                </li>
              );
            })}
          </ol>
        </div>
        <div class="mt-6 pt-4 border-t border-gray-200 dark:border-stone-800">
          <a
            href="/glossary"
            class:list={[
              "block px-3 py-1.5 rounded-md text-sm transition-colors",
              currentPath === "/glossary" || currentPath === "/glossary/"
                ? "theme-active-nav font-medium"
                : "text-gray-600 hover:text-gray-900 hover:bg-gray-50 dark:text-stone-400 dark:hover:text-stone-200 dark:hover:bg-stone-800",
            ]}
          >
            Glossary
          </a>
          <a
            href="/troubleshooting"
            class:list={[
              "block px-3 py-1.5 rounded-md text-sm transition-colors",
              currentPath === "/troubleshooting" || currentPath === "/troubleshooting/"
                ? "theme-active-nav font-medium"
                : "text-gray-600 hover:text-gray-900 hover:bg-gray-50 dark:text-stone-400 dark:hover:text-stone-200 dark:hover:bg-stone-800",
            ]}
          >
            Troubleshooting
          </a>
          <a
            id="sidebar-disenroll-link"
            href="/disenroll"
            class="hidden block px-3 py-1.5 rounded-md text-sm transition-colors text-gray-600 hover:text-gray-900 hover:bg-gray-50 dark:text-stone-400 dark:hover:text-stone-200 dark:hover:bg-stone-800"
          >
            Disenroll
          </a>
        </div>

      </nav>

      <!-- Main content -->
      <main class="flex-1 min-w-0 p-6 lg:p-12 max-w-3xl">
        <slot />
      </main>
    </div>



    <script is:inline>
      // Mobile menu toggle
      const toggle = document.getElementById("menu-toggle");
      const sidebar = document.getElementById("sidebar");
      if (toggle && sidebar) {
        toggle.addEventListener("click", () => {
          sidebar.classList.toggle("hidden");
          if (!sidebar.classList.contains("hidden")) {
            sidebar.classList.add("fixed", "inset-0", "z-50", "bg-white", "dark:bg-stone-900");
            sidebar.classList.remove("lg:block");
          } else {
            sidebar.classList.remove("fixed", "inset-0", "z-50", "bg-white", "dark:bg-stone-900");
            sidebar.classList.add("lg:block");
          }
        });
      }

      // Handle ?sid= param: save student ID from URL and clean up
      (function() {
        const params = new URLSearchParams(window.location.search);
        const sid = params.get("sid");
        if (sid) {
          window.school.setStudentId(sid);
          const url = new URL(window.location);
          url.searchParams.delete("sid");
          window.history.replaceState({}, "", url.pathname + url.search);
          window.school.updateEnrolledIndicator();
          window.school.fetchProgress().then(() => {
            window.school.updateAllCheckmarks();
          });
        } else if (window.school.getStudentId()) {
          // Show cached state immediately, then refresh from server
          window.school.updateEnrolledIndicator();
          window.school.updateAllCheckmarks();
          window.school.fetchProgress().then(() => {
            window.school.updateAllCheckmarks();
          });
        }

        // Returning students: rainbow plays briefly on every load, then fades to their color
        if (window.school.getStudentId()) {
          setTimeout(function() {
            var videoBg = document.getElementById("intro-video-bg");
            if (videoBg) videoBg.classList.remove("rainbow-bg");
          }, 1500);
        }

        // Poll for progress updates every second so the UI reflects changes
        // made by agents (e.g. marking a lesson complete) without a page reload.
        if (window.school.getStudentId()) {
          setInterval(function() {
            window.school.fetchProgress().then(function() {
              window.school.updateAllCheckmarks();
            });
          }, 1000);
        }
      })();
    </script>
  </body>
</html>
